@using PPSDotNetInternshipTraining.MVC.Models
@model IEnumerable<StudentListResponseModel>
@{ 
    ViewData["Title"] = "Student List";
    int count = 0;

}
<div class="container mt-4">
    <a href="/Student/Create" class="btn btn-primary mb-3">Create New Student</a>
    <div class="card shadow-sm">

        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Student Information List</h5>
            <span class="badge bg-primary">Total Records</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light text-nowrap">
                        <tr>
                            <th scope="col">Student No</th>
                            <th scope="col">Student Name</th>
                            <th scope="col">Father's Name</th>
                            <th scope="col">Address</th>
                            <th scope="col">Date of Birth</th>
                            <th scope="col">Status</th>
                            <th scope="col">Created At</th>
                            <th scope="col">Created By</th>
                            <th scope="col">Modified At</th>
                            <th scope="col">Modified By</th>
                            <th scope="col" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @{
                        // int currentPage = ViewBag.CurrentPage != null ? Convert.ToInt32(ViewBag.CurrentPage) : 1;
                        // int pageSize = ViewBag.PageSize != null ? Convert.ToInt32(ViewBag.PageSize) : 10;
                        // int no = ((currentPage - 1) * pageSize) + 1;
                        int no = (((int)ViewBag.CurrentPage - 1) * (int)ViewBag.PageSize) + 1;


                    }
                    @foreach (var student in Model){

                        <tr>
                        
                            <td class="text-muted">@no</td>
                            <td>@student.StudentName</td>
                            <td>@student.FatherName</td>
                            <td>@student.Address</td>
                            <td>@student.DateOfBirth</td>
                            <td><span class="badge bg-success">Active</span></td>
                            <td>@student.CreatedDateTime</td>
                            <td>@student.CreatedBy</td>
                            <td>@student.ModifiedDateTime</td>
                            <td>@student.ModifiedDateTime</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-controller="Student" asp-route-id="@student.StudentId" ><i class="bi bi-pencil"></i> Edit</a>
                                <form asp-action="Delete" method="post" class="d-inline delete-form">
                                <input type="hidden" name="id" value="@student.StudentId" />
                                <button type="button" class="btn btn-sm btn-danger btn-delete">
                                    Delete
                                </button>
                                </form>
                                </div>
                            </td>
                        </tr>
                        no++;
                    }                        
                    </tbody>
                </table>
                  <partial name="_Pagination"
        model='new PagerModel { CurrentPage = ViewBag.CurrentPage, TotalPages = ViewBag.TotalPages, Action = "Index" }' />

            @* @if (ViewBag.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-4 px-3 pb-3">

                    <span class="text-muted small">
                        Page @ViewBag.CurrentPage of @ViewBag.TotalPages
                    </span>

                    <nav aria-label="Author Page Navigation">
                        <ul class="pagination pagination-sm mb-0">

                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                    asp-route-pageNumber="@(ViewBag.CurrentPage - 1)">Previous</a>
                            </li>

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                    asp-route-pageNumber="@(ViewBag.CurrentPage + 1)">Next</a>
                            </li>

                        </ul>
                    </nav>
                </div>
            }

            <ElicitationsGroup message="Next Steps">
                <Elicitation label="Add a Search Box"
                    query="Now that I have pagination, how do I add a Search/Filter box so users can search for an author by name, while keeping the pagination working?" />
            </ElicitationsGroup> *@

        @* else
        {
            <div class="p-4 text-center text-muted">
                <p class="mb-0">No authors found. Click "Add New" to create one.</p>
            </div>
        } *@

        </div>
    </div>
</div>
@section Scripts {
    <partial name="_SweetAlertScripts" />
}