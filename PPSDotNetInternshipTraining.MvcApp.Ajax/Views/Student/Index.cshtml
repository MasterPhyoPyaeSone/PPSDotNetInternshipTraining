@{
    ViewData["Title"] = "Student CRUD";
}

<div class="container mt-4">
    <h2>Student Request Management</h2>

    <div class="card mb-4 p-3">
        <form id="studentForm">
            <input type="hidden" id="studentId" value="0" />

            <div class="row">
                <div class="col-md-3 mb-2">
                    <label>Student Name</label>
                    <input type="text" id="studentName" class="form-control" />
                </div>
                <div class="col-md-3 mb-2">
                    <label>Father Name</label>
                    <input type="text" id="fatherName" class="form-control" />
                </div>
                <div class="col-md-3 mb-2">
                    <label>Address</label>
                    <input type="text" id="address" class="form-control" />
                </div>
                <div class="col-md-3 mb-2">
                    <label>Date of Birth</label>
                    <input type="date" id="dateOfBirth" class="form-control" />
                </div>
            </div>
            <div class="mt-2">
                <button type="button" class="btn btn-primary" onclick="saveData()">Save</button>
                <button type="button" class="btn btn-secondary" onclick="clearForm()">Clear</button>
            </div>
        </form>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Father</th>
                <th>Address</th>
                <th>DOB</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="tableBody">
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            loadData();
        });

        // 1. Data ဆွဲယူခြင်း
        function loadData() {
            $.ajax({
                url: '/Student/GetAll',
                type: 'GET',
                success: function (result) {
                    var html = '';
                    $.each(result, function (key, item) {
                        var dob = item.dateOfBirth ? item.dateOfBirth.split('T')[0] : '';

                        html += '<tr>';
                        html += '<td>' + item.studentNo + '</td>';
                        html += '<td>' + item.studentName + '</td>';
                        html += '<td>' + item.fatherName + '</td>';
                        html += '<td>' + item.address + '</td>';
                        html += '<td>' + dob + '</td>';
                        html += '<td>';
                        html += '<button class="btn btn-warning btn-sm me-2" onclick="editData(' + item.studentId + ')">Edit</button>';
                        html += '<button class="btn btn-danger btn-sm" onclick="deleteData(' + item.studentId + ')">Delete</button>';
                        html += '</td>';
                        html += '</tr>';
                    });
                    $('#tableBody').html(html);
                }
            });
        }

        function saveData() {
            var studentIdVal = $('#studentId').val(); // ID ကို ယူပါမည်

            var reqObj = {
                studentId: studentIdVal,
                studentName: $('#studentName').val(),
                fatherName: $('#fatherName').val(),
                address: $('#address').val(),
                dateOfBirth: $('#dateOfBirth').val()
            };

            // ID သုညဖြစ်နေလျှင် Create, မဟုတ်လျှင် Update ဟု သတ်မှတ်မည်
            var actionUrl = (studentIdVal == "0" || studentIdVal == "") ? '/Student/Create' : '/Student/Update';

            $.ajax({
                url: actionUrl,
                type: 'POST',
                data: reqObj,
                success: function (res) {
                    if (res.success) {
                        alert(res.message);
                        clearForm();
                        loadData();
                    } else {
                        alert("Failed: " + res.message);
                    }
                },
                error: function (xhr, status, error) {
                    alert("System Error: " + error);
                    console.log("Error Details: ", xhr.responseText);
                }
            });
        }
        // 3. ပြင်ရန် Data ကို Form ထဲ ပြန်ခေါ်ခြင်း
        function editData(id) {
            $.ajax({
                url: '/Student/GetById?id=' + id,
                type: 'GET',
                success: function (res) {
                    $('#studentId').val(res.studentId);
                    $('#studentName').val(res.studentName);
                    $('#fatherName').val(res.fatherName);
                    $('#address').val(res.address);

                    if (res.dateOfBirth) {
                        var dateStr = res.dateOfBirth.split('T')[0];
                        $('#dateOfBirth').val(dateStr);
                    }
                }
            });
        }

        // 4. Data ဖျက်ခြင်း
        function deleteData(id) {
            if (confirm("Are you sure you want to delete?")) {
                $.ajax({
                    url: '/Student/Delete?id=' + id,
                    type: 'POST',
                    success: function (res) {
                        if (res.success) {
                            alert(res.message);
                            loadData();
                        }
                    }
                });
            }
        }

        // Form ရှင်းလင်းခြင်း
        function clearForm() {
            $('#studentId').val('0');
            $('#studentName').val('');
            $('#fatherName').val('');
            $('#address').val('');
            $('#dateOfBirth').val('');
        }
    </script>
}