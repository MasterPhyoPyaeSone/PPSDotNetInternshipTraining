@page "/authors"
@using PPSDotNetInternshipTraining.Blazor_HttpClient.Features.Shared.Models
@* Pagination Component ကို _Imports.razor တွင် ထည့်မထားပါက အောက်ပါလိုင်းကို ဖွင့်ပါ *@
@* @using PPSDotNetInternshipTraining.Blazor_HttpClient.Features.Shared.Components *@
@rendermode InteractiveServer
@inject AuthorService authorService
@inject NavigationManager navManager
@inject IJSRuntime JS

<h3>Authors Management</h3>

<button class="btn btn-success mb-3" @onclick="GoToCreate">+ Add New Author</button>

@if (authors == null)
{
    <p><em>Loading authors...</em></p>
}
else if (!authors.Any())
{
    <p>No authors found. Please add a new author.</p>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>No</th> @* ID အစား No (အစဉ်လိုက်နံပါတ်) ပြောင်းထားပါသည် *@
                <th>Name</th>
                <th>Bio</th>
                <th style="width: 150px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                // Page အလိုက် နံပါတ်စဉ် တွက်ချက်ခြင်း
                int count = (pager.CurrentPage - 1) * pageSize + 1;
            }
            @foreach (var author in authors)
            {
                var authorId = author.Id;
                <tr>
                    <td>@count</td>
                    <td>@author.Name</td>
                    <td>@author.Bio</td>
                    <td>
                        <button class="btn btn-warning btn-sm" @onclick="() => GoToEdit(authorId)">Edit</button>
                        <button class="btn btn-danger btn-sm ms-1" @onclick="() => ConfirmDelete(authorId)">Delete</button>
                    </td>
                </tr>
                count++;
            }
        </tbody>
    </table>

    @* Pagination Component ကို လှမ်းခေါ်ခြင်း *@
    <Pagination Pager="pager" OnPageChanged="HandlePageChanged" />
}

@code
{
    private List<AuthorResponseModel>? authors;
    
    // Pagination အတွက် လိုအပ်သော Variable များ
    private PagerModel pager = new PagerModel { CurrentPage = 1, TotalPages = 1 };
    private int pageSize = 2; // သင့် API က 1 ဆိုရင် 1 လို့ ပြင်ပါ

    protected override async Task OnInitializedAsync()
    {
        await LoadAuthors(1); // စစချင်း Page 1 ကို ခေါ်မည်
    }

    // Pagination မှ Page အသစ် နှိပ်လိုက်တိုင်း အလုပ်လုပ်မည့် Method
    private async Task HandlePageChanged(int newPage)
    {
        await LoadAuthors(newPage);
    }

    private async Task LoadAuthors(int pageNumber = 1)
    {
        // ⚠️ သတိပြုရန်: အရင်အပတ်က ကျွန်တော်တို့ ဆွေးနွေးခဲ့သလို 
        // authorService.GetAuthorsAsync(pageNumber) က PaginatedResponse ပြန်ပေးဖို့ လိုအပ်ပါတယ်။
        var response = await authorService.GetAuthorsAsync(pageNumber);

        if (response != null)
        {
            authors = response.Data;
            pager = new PagerModel 
            { 
                CurrentPage = response.CurrentPage, 
                TotalPages = response.TotalPages 
            };
        }
    }

    private void GoToCreate()
    {
        navManager.NavigateTo("/authors/create");
    }

    private void GoToEdit(int id)
    {
        navManager.NavigateTo($"/authors/edit/{id}");
    }

    private async Task ConfirmDelete(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this author?");
        if (confirmed)
        {
            await DeleteAuthor(id);
        }
    }

    private async Task DeleteAuthor(int id)
    {
        await authorService.DeleteAuthorAsync(id);
        await LoadAuthors(pager.CurrentPage); // ဖျက်ပြီးပါက လက်ရှိ Page ကိုသာ ပြန်ခေါ်ပါ
    }
}